msgid "Nora"
msgstr "Nora"

msgid "Manage the Nora private npm registry on OpenWrt."
msgstr "在 OpenWrt 上管理 Nora 私有 npm 仓库。"

msgid "Global service settings"
msgstr "全局服务设置"

msgid "Enable service"
msgstr "启用服务"

msgid "Install directory"
msgstr "安装目录"

msgid "Target version"
msgstr "目标版本"

msgid "Use latest or a release such as v0.5.0."
msgstr "可填写 latest 或类似 v0.5.0 的版本号。"

msgid "Architecture"
msgstr "架构"

msgid "Auto detect"
msgstr "自动检测"

msgid "Host"
msgstr "主机"

msgid "Port"
msgstr "端口"

msgid "Public URL"
msgstr "公共 URL"

msgid "Leave empty is allowed, but when host is 0.0.0.0 clients may receive unreachable URLs."
msgstr "允许留空，但当 host 为 0.0.0.0 时，客户端可能收到不可达的 URL。"

msgid "Authentication settings"
msgstr "认证设置"

msgid "Enable authentication"
msgstr "启用认证"

msgid "Allow anonymous read"
msgstr "允许匿名读取"

