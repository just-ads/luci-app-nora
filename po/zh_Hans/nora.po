msgstr "htpasswd 文件"

msgid "Token storage"
msgstr "Token 存储目录"

msgid "npm registry settings"
msgstr "npm 仓库设置"

msgid "Enable npm registry"
msgstr "启用 npm 仓库"

msgid "Upstream proxy"
msgstr "上游代理"

msgid "Leave this empty for private packages only."
msgstr "留空表示仅提供私有包，不使用上游代理。"

msgid "Proxy timeout (seconds)"
msgstr "代理超时（秒）"

msgid "Metadata TTL (seconds)"
msgstr "元数据 TTL（秒）"

msgid "Storage path"
msgstr "存储路径"

msgid "Firewall settings"
msgstr "防火墙设置"

msgid "Manage firewall rule"
msgstr "管理防火墙规则"

msgid "Source zone"
msgstr "来源区域"

msgid "Default is lan. When disabled, only the named firewall section nora is removed."
msgstr "默认值为 lan。禁用时仅删除名为 nora 的防火墙 section。"

msgid "Enabled"
msgstr "已启用"

msgid "Disabled"
msgstr "已禁用"

msgid "Operation completed"
msgstr "操作已完成"

msgid "Loading..."
msgstr "加载中..."

msgid "Service actions"
msgstr "服务操作"

msgid "Use these runtime controls after saving any related configuration changes."
msgstr "请在保存相关配置变更后使用这些运行时控制。"

msgid "Service status"
msgstr "服务状态"

msgid "Running"
msgstr "运行中"

msgid "Stopped"
msgstr "已停止"

msgid "Runtime state detected from the existing Nora service."
msgstr "运行状态由当前 Nora 服务检测得出。"

msgid "Install Nora before starting the service."
msgstr "请先安装 Nora 再启动服务。"

msgid "Current version"
msgstr "当前版本"

msgid "Detected but version string is unavailable"
msgstr "已检测到，但版本字符串不可用"

