config main 'config'
	option enabled '0'
	option install_dir '/opt/nora'
	option version 'latest'
	option architecture 'auto'
	option host '0.0.0.0'
	option port '4873'
	option public_url ''
	option storage_path '/opt/nora/data/storage'
	option auth_enabled '1'
	option anonymous_read '0'
	option htpasswd_file '/opt/nora/config/users.htpasswd'
	option token_storage '/opt/nora/data/tokens'
	option npm_enabled '1'
	option npm_proxy ''
	option npm_proxy_timeout '30'
	option npm_metadata_ttl '300'
	option allow_wan_access '0'
