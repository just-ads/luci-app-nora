{
	"luci-app-nora": {
		"description": "Grant access to LuCI Nora management",
		"read": {
			"uci": [ "nora" ],
			"ubus": {
				"luci.nora": [ "status", "latest_version", "plugin_status", "plugin_latest_version", "read_uci_config", "read_nora_config", "logs" ]
			}
		},
		"write": {
			"cgi-io": [ "upload" ],
			"file": {
				"/tmp/nora-upload-*": [ "write" ]
			},
			"uci": [ "nora" ],
			"ubus": {
				"luci.nora": [ "install", "upgrade", "plugin_upgrade", "upload_binary", "render_nora_config", "save_settings", "start", "stop", "restart", "set_htpasswd", "firewall_apply" ]
			}
		}
	}
}
