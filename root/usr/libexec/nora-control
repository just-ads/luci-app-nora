#!/bin/sh

. /lib/functions.sh
. /usr/share/libubox/jshn.sh

UCI_CONFIG="nora"
UCI_SECTION="config"
SERVICE_SCRIPT="/etc/init.d/nora"
NORA_REPO="getnora-io/nora"
PLUGIN_PACKAGE="luci-app-nora"
PLUGIN_I18N_PACKAGE="luci-i18n-nora-zh-cn"
PLUGIN_REPO="just-ads/luci-app-nora"
DEFAULT_LOG_MAX_SIZE="1048576"
DEFAULT_LOG_READ_LIMIT="262144"
MAX_LOG_READ_LIMIT="2097152"
DEFER_RPCD_RELOAD_MARKER="/tmp/.nora-defer-rpcd-reload"
NEEDS_RPCD_RELOAD_MARKER="/tmp/luci-app-nora.needs-rpcd-reload"

# -----------------------------------------------------------------------------
# Common utilities
# -----------------------------------------------------------------------------

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g' | awk '{ if (NR > 1) printf "\\n"; printf "%s", $0 }'
}

log_timestamp() {
	date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%SZ'
}

plugin_log_path() {
	local install_dir
	install_dir="$(uci -q get "$UCI_CONFIG.$UCI_SECTION.install_dir" 2>/dev/null)"
	[ -n "$install_dir" ] || install_dir='/opt/nora'
	printf '%s/logs/plugin.log' "$install_dir"
}

plugin_log_max_size() {
	local max_size
	max_size="$(uci -q get "$UCI_CONFIG.$UCI_SECTION.plugin_log_max_size" 2>/dev/null)"
	validate_log_size "$max_size" 2>/dev/null || max_size="$DEFAULT_LOG_MAX_SIZE"
	printf '%s' "$max_size"
}

truncate_log_if_needed() {
	local log_file="$1" max_size="$2" target="$3" size dir ts marker
	dir="$(dirname "$log_file")"
	mkdir -p "$dir" >/dev/null 2>&1 || return 1
	[ -f "$log_file" ] || return 0
	size="$(wc -c < "$log_file" 2>/dev/null | tr -d ' ')"
	is_uint "$size" || size=0
	[ "$size" -le "$max_size" ] && return 0
	ts="$(log_timestamp)"
	marker="{\"timestamp\":\"$(json_escape "$ts")\",\"level\":\"WARN\",\"fields\":{\"message\":\"log exceeded max size, truncated\",\"max_size\":$max_size},\"target\":\"$(json_escape "$target")\"}"
	: > "$log_file" 2>/dev/null || return 1
	printf '%s\n' "$marker" >> "$log_file" 2>/dev/null || return 1
}

plugin_log() {
	local level="$1" action="$2" message="$3" log_file max_size ts line
	[ -n "$level" ] || level='INFO'
	[ -n "$action" ] || action='unknown'
	[ -n "$message" ] || message=''
	log_file="$(plugin_log_path)"
	max_size="$(plugin_log_max_size)"
	truncate_log_if_needed "$log_file" "$max_size" 'luci-app-nora' >/dev/null 2>&1 || return 0
	ts="$(log_timestamp)"
	line="{\"timestamp\":\"$(json_escape "$ts")\",\"level\":\"$(json_escape "$level")\",\"fields\":{\"message\":\"$(json_escape "$message")\",\"action\":\"$(json_escape "$action")\"},\"target\":\"luci-app-nora\"}"
	printf '%s\n' "$line" >> "$log_file" 2>/dev/null || true
}

fail() {
	local message="$1"
	plugin_log ERROR error "$message"
	json_init
	json_add_boolean success 0
	json_add_string error "$message"
	json_dump
	exit 1
}

ok_message() {
	local action="$1"
	local message="$2"
	case "$action" in
		status|logs|read-uci-config|read-nora-config) ;;
		*) plugin_log INFO "$action" "$message" ;;
	esac
	json_init
	json_add_boolean success 1
	json_add_string action "$action"
	json_add_string message "$message"
	json_dump
}

require_command() {
	command -v "$1" >/dev/null 2>&1 || fail "missing command: $1"
}

ensure_uci_section() {
	require_command uci
	uci -q get "$UCI_CONFIG.$UCI_SECTION" >/dev/null 2>&1 || uci set "$UCI_CONFIG.$UCI_SECTION=main" >/dev/null 2>&1 || fail "failed to create UCI section"
}

set_uci_option() {
	uci set "$UCI_CONFIG.$UCI_SECTION.$1=$2" >/dev/null 2>&1 || fail "failed to save $1"
}

json_get_setting_value() {
	local dest="$1" key="$2" current="$3" type value

	if ! json_get_type type "$key"; then
		eval "$dest=\"\$current\""
		return 0
	fi

	case "$type" in
		null)
			value=''
			;;
		string|int|double|boolean)
			json_get_var value "$key" || value=''
			;;
		*)
			return 1
			;;
	esac

	eval "$dest=\"\$value\""
}

delete_uci_option() {
	uci -q delete "$UCI_CONFIG.$UCI_SECTION.$1" >/dev/null 2>&1 || true
}

commit_uci_config() {
	uci commit "$UCI_CONFIG" >/dev/null 2>&1 || fail "failed to commit UCI config"
}

is_bool() {
	case "$1" in
		0|1) return 0 ;;
		*) return 1 ;;
	esac
}

normalize_bool() {
	case "$1" in
		1|true|TRUE|on|ON|yes|YES) printf 1 ;;
		0|false|FALSE|off|OFF|no|NO) printf 0 ;;
		*) return 1 ;;
	esac
}

is_uint() {
	case "$1" in
		''|*[!0-9]*) return 1 ;;
		*) return 0 ;;
	esac
}

validate_log_size() {
	is_uint "$1" || return 1
	[ "$1" -ge 4096 ] && [ "$1" -le 16777216 ]
}

normalize_limit_bytes() {
	local limit="$1"
	if ! is_uint "$limit" || [ "$limit" -le 0 ]; then
		limit="$DEFAULT_LOG_READ_LIMIT"
	fi
	[ "$limit" -le "$MAX_LOG_READ_LIMIT" ] || limit="$MAX_LOG_READ_LIMIT"
	printf '%s' "$limit"
}

validate_port() {
	is_uint "$1" || return 1
	[ "$1" -ge 1 ] && [ "$1" -le 65535 ]
}

validate_timeout() {
	is_uint "$1" || return 1
	[ "$1" -ge 0 ] && [ "$1" -le 86400 ]
}

validate_version() {
	[ "$1" = "latest" ] && return 0
	printf '%s' "$1" | grep -Eq '^v?[0-9]+(\.[0-9]+)+([.-][A-Za-z0-9]+)*([+][A-Za-z0-9.]+)?$'
}

validate_architecture() {
	case "$1" in
		auto|amd64|arm64|armv7) return 0 ;;
		*) return 1 ;;
	esac
}

validate_abs_path() {
	case "$1" in
		/*)
			printf '%s' "$1" | grep -Eq '^/[A-Za-z0-9._/+-]+$'
			return $?
			;;
		*) return 1 ;;
	esac
}

validate_upload_path() {
	case "$1" in
		/tmp/nora-upload-*) validate_abs_path "$1" ;;
		*) return 1 ;;
	esac
}

validate_host() {
	printf '%s' "$1" | grep -Eq '^[A-Za-z0-9:._-]+$'
}

is_ipv4_addr() {
	printf '%s' "$1" | grep -Eq '^([0-9]{1,3}\.){3}[0-9]{1,3}$'
}

valid_detected_ip() {
	[ -n "$1" ] && [ "$1" != "0.0.0.0" ] && is_ipv4_addr "$1"
}

validate_url_or_empty() {
	local url="$1"

	[ -z "$url" ] && return 0
	case "$url" in
		http://*|https://*) ;;
		*) return 1 ;;
	esac
	printf '%s' "$url" | grep -Eq '^[^[:space:]<>"]+$'
}

github_latest_release() {
	local repository="$1"

	command -v wget >/dev/null 2>&1 || return 1
	wget -q -O - "https://api.github.com/repos/$repository/releases/latest" 2>/dev/null
}

github_release_tag_from_json() {
	sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | sed -n '1p'
}

toml_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

# -----------------------------------------------------------------------------
# Nora operations
# -----------------------------------------------------------------------------

detect_openwrt_ip() {
	local ip candidate

	if command -v ubus >/dev/null 2>&1 && command -v jsonfilter >/dev/null 2>&1; then
		ip="$(ubus call network.interface.lan status 2>/dev/null | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null)"
		for candidate in $ip; do
			candidate="${candidate%%/*}"
			if valid_detected_ip "$candidate"; then
				printf '%s' "$candidate"
				return 0
			fi
		done
	fi

	ip="$(uci -q get network.lan.ipaddr 2>/dev/null)"
	for candidate in $ip; do
		candidate="${candidate%%/*}"
		if valid_detected_ip "$candidate"; then
			printf '%s' "$candidate"
			return 0
		fi
	done

	return 1
}

default_public_url() {
	local ip

	ip="$(default_lan_ip)"
	printf 'http://%s:%s' "$ip" "$CFG_PORT"
}

default_lan_ip() {
	detect_openwrt_ip || printf '%s' '192.168.1.1'
}

default_host() {
	printf '%s' '0.0.0.0'
}

normalize_host() {
	case "$CFG_HOST" in
		''|192.168.1.1)
			CFG_HOST="$(default_host)"
			;;
	esac
}

normalize_public_url() {
	CFG_PUBLIC_URL="$(default_public_url)"
}

detect_nora_latest_version() {
	github_latest_release "$NORA_REPO" | github_release_tag_from_json
}

collect_nora_latest_version() {
	local latest_version
	latest_version="$(detect_nora_latest_version || true)"
	json_init
	json_add_boolean success 1
	json_add_string action latest-version
	json_add_string latest_version "$latest_version"
	json_dump
}

validate_username() {
	printf '%s' "$1" | grep -Eq '^[A-Za-z0-9._-]+$'
}

validate_bcrypt_hash() {
	printf '%s' "$1" | grep -Eq '^\$2[aby]\$[0-9]{2}\$[./A-Za-z0-9]{53}$'
}

validate_htpasswd_line() {
	local line="$1"
	local user hash rest

	[ "$(printf '%s' "$line" | wc -l | tr -d ' ')" = "0" ] || return 1
	case "$line" in
		*"$(printf '\r')"*) return 1 ;;
	esac

	user="${line%%:*}"
	rest="${line#*:}"
	[ -n "$user" ] || return 1
	[ "$line" != "$rest" ] || return 1
	case "$rest" in
		*:* ) return 1 ;;
	esac
	hash="$rest"
	validate_username "$user" || return 1
	validate_bcrypt_hash "$hash" || return 1
	return 0
}

resolve_architecture() {
	local configured="$1"
	local detected

	if [ "$configured" != "auto" ]; then
		printf '%s' "$configured"
		return 0
	fi

	detected="$(uname -m 2>/dev/null)"
	case "$detected" in
		x86_64) printf '%s' 'amd64' ;;
		aarch64) printf '%s' 'arm64' ;;
		armv7* ) printf '%s' 'armv7' ;;
		*) return 1 ;;
	esac
}

normalize_nora_version() {
	case "$1" in
		latest) printf '%s' 'latest' ;;
		v*) printf '%s' "$1" ;;
		*) printf 'v%s' "$1" ;;
	esac
}

detect_nora_binary_version() {
	local binary="$1"
	[ -x "$binary" ] || return 1
	"$binary" --version 2>/dev/null || "$binary" version 2>/dev/null
}

config_load_raw_values() {
	config_load "$UCI_CONFIG" || fail "unable to load UCI config nora"

	config_get CFG_INSTALL_DIR "$UCI_SECTION" install_dir '/opt/nora'
	config_get CFG_VERSION "$UCI_SECTION" version 'latest'
	config_get CFG_ARCHITECTURE "$UCI_SECTION" architecture 'auto'
	CFG_HOST="$(default_host)"
	config_get CFG_PORT "$UCI_SECTION" port '4873'
	CFG_PUBLIC_URL=""
	config_get CFG_STORAGE_PATH "$UCI_SECTION" storage_path "$CFG_INSTALL_DIR/data/storage"
	config_get_bool CFG_AUTH_ENABLED "$UCI_SECTION" auth_enabled 1
	config_get_bool CFG_ANONYMOUS_READ "$UCI_SECTION" anonymous_read 0
	config_get CFG_HTPASSWD_FILE "$UCI_SECTION" htpasswd_file "$CFG_INSTALL_DIR/config/users.htpasswd"
	config_get CFG_TOKEN_STORAGE "$UCI_SECTION" token_storage "$CFG_INSTALL_DIR/data/tokens"
	config_get_bool CFG_NPM_ENABLED "$UCI_SECTION" npm_enabled 1
	config_get CFG_NPM_PROXY "$UCI_SECTION" npm_proxy ''
	config_get CFG_NPM_PROXY_TIMEOUT "$UCI_SECTION" npm_proxy_timeout '30'
	config_get CFG_NPM_METADATA_TTL "$UCI_SECTION" npm_metadata_ttl '300'
	config_get_bool CFG_ALLOW_WAN_ACCESS "$UCI_SECTION" allow_wan_access 0
	config_get CFG_NORA_LOG_MAX_SIZE "$UCI_SECTION" nora_log_max_size "$DEFAULT_LOG_MAX_SIZE"
	config_get CFG_PLUGIN_LOG_MAX_SIZE "$UCI_SECTION" plugin_log_max_size "$DEFAULT_LOG_MAX_SIZE"
	normalize_host
}

config_load_values() {
	config_load_raw_values

	validate_config_values
}

config_load_path_values() {
	config_load_raw_values
	validate_abs_path "$CFG_INSTALL_DIR" || fail "invalid install_dir"
}

config_load_htpasswd_values() {
	config_load_raw_values
	validate_abs_path "$CFG_INSTALL_DIR" || fail "invalid install_dir"
	validate_abs_path "$CFG_HTPASSWD_FILE" || fail "invalid htpasswd_file"
}

config_load_firewall_values() {
	config_load_raw_values
	validate_port "$CFG_PORT" || fail "invalid port"
	is_bool "$CFG_ALLOW_WAN_ACCESS" || fail "invalid allow_wan_access"
}

config_load_upgrade_values() {
	config_load "$UCI_CONFIG" || fail "unable to load UCI config nora"
	config_get CFG_VERSION "$UCI_SECTION" version 'latest'
	validate_version "$CFG_VERSION" || fail "invalid version"
}

config_load_nora_binary_values() {
	config_load "$UCI_CONFIG" || fail "unable to load UCI config nora"

	config_get CFG_INSTALL_DIR "$UCI_SECTION" install_dir '/opt/nora'
	config_get CFG_ARCHITECTURE "$UCI_SECTION" architecture 'auto'

	validate_abs_path "$CFG_INSTALL_DIR" || fail "invalid install_dir"
	validate_architecture "$CFG_ARCHITECTURE" || fail "invalid architecture"
	CFG_RESOLVED_ARCH="$(resolve_architecture "$CFG_ARCHITECTURE")" || fail "unsupported auto architecture: $(uname -m 2>/dev/null)"
}

validate_config_values() {
	validate_abs_path "$CFG_INSTALL_DIR" || fail "invalid install_dir"
	validate_version "$CFG_VERSION" || fail "invalid version"
	validate_architecture "$CFG_ARCHITECTURE" || fail "invalid architecture"
	validate_host "$CFG_HOST" || fail "invalid host"
	validate_port "$CFG_PORT" || fail "invalid port"
	normalize_public_url
	validate_url_or_empty "$CFG_PUBLIC_URL" || fail "invalid public_url"
	validate_abs_path "$CFG_STORAGE_PATH" || fail "invalid storage_path"
	is_bool "$CFG_AUTH_ENABLED" || fail "invalid auth_enabled"
	is_bool "$CFG_ANONYMOUS_READ" || fail "invalid anonymous_read"
	validate_abs_path "$CFG_HTPASSWD_FILE" || fail "invalid htpasswd_file"
	validate_abs_path "$CFG_TOKEN_STORAGE" || fail "invalid token_storage"
	is_bool "$CFG_NPM_ENABLED" || fail "invalid npm_enabled"
	validate_url_or_empty "$CFG_NPM_PROXY" || fail "invalid npm_proxy"
	validate_timeout "$CFG_NPM_PROXY_TIMEOUT" || fail "invalid npm_proxy_timeout"
	validate_timeout "$CFG_NPM_METADATA_TTL" || fail "invalid npm_metadata_ttl"
	is_bool "$CFG_ALLOW_WAN_ACCESS" || fail "invalid allow_wan_access"
	validate_log_size "$CFG_NORA_LOG_MAX_SIZE" || fail "invalid nora_log_max_size"
	validate_log_size "$CFG_PLUGIN_LOG_MAX_SIZE" || fail "invalid plugin_log_max_size"
	CFG_RESOLVED_ARCH="$(resolve_architecture "$CFG_ARCHITECTURE")" || fail "unsupported auto architecture: $(uname -m 2>/dev/null)"

	if [ "$CFG_AUTH_ENABLED" -eq 1 ] && [ -f "$CFG_HTPASSWD_FILE" ]; then
		validate_htpasswd_line "$(cat "$CFG_HTPASSWD_FILE" 2>/dev/null)" || fail "invalid htpasswd file"
	fi
}

log_file_for_type() {
	local type="$1"
	case "$type" in
		nora) printf '%s/logs/nora.log' "$CFG_INSTALL_DIR" ;;
		plugin) printf '%s/logs/plugin.log' "$CFG_INSTALL_DIR" ;;
		*) fail "invalid log type" ;;
	esac
}

log_max_size_for_type() {
	local type="$1"
	case "$type" in
		nora) printf '%s' "$CFG_NORA_LOG_MAX_SIZE" ;;
		plugin) printf '%s' "$CFG_PLUGIN_LOG_MAX_SIZE" ;;
		*) fail "invalid log type" ;;
	esac
}

read_logs() {
	local type="$1" offset="$2" limit_bytes="$3" log_file max_size size start count truncated initial prev_byte
	local tmp raw trimmed final raw_bytes trimmed_bytes content_bytes next_offset content last_byte
	config_load_raw_values
	validate_log_size "$CFG_NORA_LOG_MAX_SIZE" || CFG_NORA_LOG_MAX_SIZE="$DEFAULT_LOG_MAX_SIZE"
	validate_log_size "$CFG_PLUGIN_LOG_MAX_SIZE" || CFG_PLUGIN_LOG_MAX_SIZE="$DEFAULT_LOG_MAX_SIZE"

	case "$type" in nora|plugin) ;; *) fail "invalid log type" ;; esac
	limit_bytes="$(normalize_limit_bytes "$limit_bytes")"
	log_file="$(log_file_for_type "$type")"
	max_size="$(log_max_size_for_type "$type")"
	truncate_log_if_needed "$log_file" "$max_size" "$type" >/dev/null 2>&1 || true

	if [ ! -f "$log_file" ]; then
		json_init
		json_add_boolean success 1
		json_add_string action logs
		json_add_string type "$type"
		json_add_string path "$log_file"
		json_add_int offset 0
		json_add_int next_offset 0
		json_add_int size 0
		json_add_int limit_bytes "$limit_bytes"
		json_add_boolean truncated 0
		json_add_boolean partial 0
		json_add_string content ''
		json_dump
		return 0
	fi

	size="$(wc -c < "$log_file" 2>/dev/null | tr -d ' ')"
	is_uint "$size" || size=0
	truncated=0
	initial=0
	if ! is_uint "$offset"; then
		initial=1
		if [ "$size" -gt "$limit_bytes" ]; then
			start=$((size - limit_bytes))
		else
			start=0
		fi
	elif [ "$offset" -gt "$size" ]; then
		truncated=1
		initial=1
		if [ "$size" -gt "$limit_bytes" ]; then
			start=$((size - limit_bytes))
		else
			start=0
		fi
	else
		start="$offset"
	fi

	count=$((size - start))
	[ "$count" -le "$limit_bytes" ] || count="$limit_bytes"
	[ "$count" -gt 0 ] || count=0
	tmp="/tmp/nora-log-read.$$"
	raw="$tmp.raw"
	trimmed="$tmp.trimmed"
	final="$tmp.final"
	rm -f "$raw" "$trimmed" "$final"
	if [ "$count" -gt 0 ]; then
		dd if="$log_file" of="$raw" bs=1 skip="$start" count="$count" 2>/dev/null || : > "$raw"
	else
		: > "$raw"
	fi
	raw_bytes="$(wc -c < "$raw" 2>/dev/null | tr -d ' ')"
	is_uint "$raw_bytes" || raw_bytes=0

	if [ "$initial" -eq 1 ] && [ "$start" -gt 0 ] && [ "$raw_bytes" -gt 0 ]; then
		prev_byte="$(dd if="$log_file" bs=1 skip=$((start - 1)) count=1 2>/dev/null)"
	fi

	if [ "$initial" -eq 1 ] && [ "$start" -gt 0 ] && [ "$raw_bytes" -gt 0 ] && [ -n "$prev_byte" ]; then
		sed '1d' "$raw" > "$trimmed" 2>/dev/null || : > "$trimmed"
		trimmed_bytes="$(wc -c < "$trimmed" 2>/dev/null | tr -d ' ')"
		is_uint "$trimmed_bytes" || trimmed_bytes=0
		start=$((start + raw_bytes - trimmed_bytes))
	else
		mv -f "$raw" "$trimmed"
	fi

	trimmed_bytes="$(wc -c < "$trimmed" 2>/dev/null | tr -d ' ')"
	is_uint "$trimmed_bytes" || trimmed_bytes=0
	if [ "$trimmed_bytes" -gt 0 ]; then
		last_byte="$(tail -c 1 "$trimmed" 2>/dev/null)"
		if [ "$last_byte" = "$(printf '\n')" ]; then
			cp "$trimmed" "$final" 2>/dev/null || : > "$final"
		else
			sed '$d' "$trimmed" > "$final" 2>/dev/null || : > "$final"
		fi
	else
		: > "$final"
	fi

	content_bytes="$(wc -c < "$final" 2>/dev/null | tr -d ' ')"
	is_uint "$content_bytes" || content_bytes=0
	next_offset=$((start + content_bytes))
	content="$(cat "$final" 2>/dev/null)"
	rm -f "$raw" "$trimmed" "$final"

	json_init
	json_add_boolean success 1
	json_add_string action logs
	json_add_string type "$type"
	json_add_string path "$log_file"
	json_add_int offset "$start"
	json_add_int next_offset "$next_offset"
	json_add_int size "$size"
	json_add_int limit_bytes "$limit_bytes"
	json_add_boolean truncated "$truncated"
	json_add_boolean partial "$( [ "$next_offset" -lt "$size" ] && printf 1 || printf 0 )"
	json_add_string content "$content"
	json_dump
}

ensure_directories() {
	mkdir -p "$CFG_INSTALL_DIR" "$CFG_INSTALL_DIR/bin" "$CFG_INSTALL_DIR/config" "$CFG_STORAGE_PATH" "$CFG_TOKEN_STORAGE" || fail "failed to create directories"
	mkdir -p "$(dirname "$CFG_HTPASSWD_FILE")" || fail "failed to create htpasswd directory"
}

render_nora_config() {
	local output tmp public_line npm_proxy_line
	config_load_values
	ensure_directories
	output="$CFG_INSTALL_DIR/config/config.toml"
	tmp="$output.tmp.$$"

	if [ "$CFG_AUTH_ENABLED" -eq 1 ]; then
		[ -s "$CFG_HTPASSWD_FILE" ] || fail "htpasswd file missing while auth is enabled"
		validate_htpasswd_line "$(cat "$CFG_HTPASSWD_FILE" 2>/dev/null)" || fail "invalid htpasswd file"
	fi

	public_line="public_url = \"$(toml_escape "$CFG_PUBLIC_URL")\""

	npm_proxy_line="proxy = \"$(toml_escape "$CFG_NPM_PROXY")\""

	umask 077
	cat > "$tmp" <<EOF
[server]
host = "$(toml_escape "$CFG_HOST")"
port = $CFG_PORT
$public_line

[storage]
mode = "local"
path = "$(toml_escape "$CFG_STORAGE_PATH")"

[auth]
enabled = $( [ "$CFG_AUTH_ENABLED" -eq 1 ] && printf true || printf false )
anonymous_read = $( [ "$CFG_ANONYMOUS_READ" -eq 1 ] && printf true || printf false )
htpasswd_file = "$(toml_escape "$CFG_HTPASSWD_FILE")"
token_storage = "$(toml_escape "$CFG_TOKEN_STORAGE")"

[secrets]
provider = "env"

[rate_limit]
enabled = false

[npm]
enabled = $( [ "$CFG_NPM_ENABLED" -eq 1 ] && printf true || printf false )
$npm_proxy_line
proxy_timeout = $CFG_NPM_PROXY_TIMEOUT
metadata_ttl = $CFG_NPM_METADATA_TTL

[docker]
enabled = false
[maven]
enabled = false
[cargo]
enabled = false
[pypi]
enabled = false
[go]
enabled = false
[raw]
enabled = false
[gems]
enabled = false
[terraform]
enabled = false
[ansible]
enabled = false
[nuget]
enabled = false
[pub_dart]
enabled = false
[conan]
enabled = false

[gc]
enabled = false
[retention]
enabled = false
[curation]
mode = "off"
EOF
	[ $? -eq 0 ] || fail "failed to write config"
	mv -f "$tmp" "$output" || fail "failed to install config"
	ok_message "render-nora-config" "rendered $output"
}

read_nora_config() {
	local config_path content

	config_load_path_values
	config_path="$CFG_INSTALL_DIR/config/config.toml"
	[ -f "$config_path" ] || fail "Nora config does not exist; render it first"
	content="$(cat "$config_path" 2>/dev/null)" || fail "failed to read Nora config"

	json_init
	json_add_boolean success 1
	json_add_string action "read-nora-config"
	json_add_string path "$config_path"
	json_add_string content "$content"

	local host port public_url storage_path auth_enabled anonymous_read htpasswd_file token_storage
	local npm_enabled npm_proxy npm_proxy_timeout npm_metadata_ttl

	host=$(sed -n '/^\[server\]/,/^\[/s/^host = "\(.*\)"/\1/p' "$config_path" | head -1)
	port=$(sed -n '/^\[server\]/,/^\[/s/^port = \([0-9]*\)/\1/p' "$config_path" | head -1)
	public_url=$(sed -n '/^\[server\]/,/^\[/s/^public_url = "\(.*\)"/\1/p' "$config_path" | head -1)
	storage_path=$(sed -n '/^\[storage\]/,/^\[/s/^path = "\(.*\)"/\1/p' "$config_path" | head -1)
	auth_enabled=$(sed -n '/^\[auth\]/,/^\[/s/^enabled = \(true\|false\)/\1/p' "$config_path" | head -1)
	anonymous_read=$(sed -n '/^\[auth\]/,/^\[/s/^anonymous_read = \(true\|false\)/\1/p' "$config_path" | head -1)
	htpasswd_file=$(sed -n '/^\[auth\]/,/^\[/s/^htpasswd_file = "\(.*\)"/\1/p' "$config_path" | head -1)
	token_storage=$(sed -n '/^\[auth\]/,/^\[/s/^token_storage = "\(.*\)"/\1/p' "$config_path" | head -1)
	npm_enabled=$(sed -n '/^\[npm\]/,/^\[/s/^enabled = \(true\|false\)/\1/p' "$config_path" | head -1)
	npm_proxy=$(sed -n '/^\[npm\]/,/^\[/s/^proxy = "\(.*\)"/\1/p' "$config_path" | head -1)
	npm_proxy_timeout=$(sed -n '/^\[npm\]/,/^\[/s/^proxy_timeout = \([0-9]*\)/\1/p' "$config_path" | head -1)
	npm_metadata_ttl=$(sed -n '/^\[npm\]/,/^\[/s/^metadata_ttl = \([0-9]*\)/\1/p' "$config_path" | head -1)

	json_add_object server
	[ -n "$host" ] && json_add_string host "$host"
	[ -n "$port" ] && json_add_int port "$port"
	[ -n "$public_url" ] && json_add_string public_url "$public_url"
	json_close_object

	json_add_object storage
	[ -n "$storage_path" ] && json_add_string path "$storage_path"
	json_close_object

	json_add_object auth
	[ -n "$auth_enabled" ] && json_add_boolean auth_enabled "$([ "$auth_enabled" = "true" ] && printf 1 || printf 0)"
	[ -n "$anonymous_read" ] && json_add_boolean anonymous_read "$([ "$anonymous_read" = "true" ] && printf 1 || printf 0)"
	[ -n "$htpasswd_file" ] && json_add_string htpasswd_file "$htpasswd_file"
	[ -n "$token_storage" ] && json_add_string token_storage "$token_storage"
	json_close_object

	json_add_object npm
	[ -n "$npm_enabled" ] && json_add_boolean npm_enabled "$([ "$npm_enabled" = "true" ] && printf 1 || printf 0)"
	[ -n "$npm_proxy" ] && json_add_string npm_proxy "$npm_proxy"
	[ -n "$npm_proxy_timeout" ] && json_add_int npm_proxy_timeout "$npm_proxy_timeout"
	[ -n "$npm_metadata_ttl" ] && json_add_int npm_metadata_ttl "$npm_metadata_ttl"
	[ -n "$storage_path" ] && json_add_string storage_path "$storage_path"
	json_close_object

	json_dump
}

finish_save_settings() {
	local section="$1" apply_firewall="$2" restart_nora="$3" was_running=0

	SAVE_SETTINGS_MESSAGE="settings saved"
	if [ "$restart_nora" -eq 1 ] && detect_running "$CFG_INSTALL_DIR/bin/nora"; then
		was_running=1
	fi

	commit_uci_config
	plugin_log INFO save-settings "$section settings committed"
	render_nora_config >/dev/null 2>&1 || fail "settings saved but failed to render Nora config"
	plugin_log INFO save-settings "Nora config regenerated after saving $section settings"

	if [ "$was_running" -eq 1 ]; then
		[ -x "$SERVICE_SCRIPT" ] || fail "settings saved but service script missing"
		"$SERVICE_SCRIPT" restart >/dev/null 2>&1 || fail "settings saved but failed to restart Nora"
		plugin_log INFO save-settings "Nora restarted after saving $section settings"
		SAVE_SETTINGS_MESSAGE="settings saved and Nora restarted"
	fi

	if [ "$apply_firewall" -ne 0 ]; then
		plugin_log INFO save-settings "applying firewall after saving $section settings"
		firewall_apply >/dev/null 2>&1 || fail "settings saved but failed to apply firewall"
	fi
}

save_settings() {
	local section="$1"
	local settings_json changed=0 apply_firewall=0 restart_nora=0

	SAVE_SETTINGS_MESSAGE="settings saved"
	settings_json="$(cat)" || fail "failed to read settings"
	config_load_raw_values
	plugin_log INFO save-settings "saving $section settings"

	json_init
	json_load "$settings_json" 2>/dev/null || json_load '{}' 2>/dev/null

	case "$section" in
		global)
			local install_dir boot_enabled host port allow_wan_access nora_log_max_size plugin_log_max_size
			json_get_setting_value install_dir install_dir "$CFG_INSTALL_DIR" || fail "invalid install_dir"
			json_get_setting_value boot_enabled boot_enabled "$(service_boot_enabled && printf 1 || printf 0)" || fail "invalid boot_enabled"
			host="$(default_host)"
			json_get_setting_value port port "$CFG_PORT" || fail "invalid port"
			json_get_setting_value allow_wan_access allow_wan_access "$CFG_ALLOW_WAN_ACCESS" || fail "invalid allow_wan_access"
			json_get_setting_value nora_log_max_size nora_log_max_size "$CFG_NORA_LOG_MAX_SIZE" || fail "invalid nora_log_max_size"
			json_get_setting_value plugin_log_max_size plugin_log_max_size "$CFG_PLUGIN_LOG_MAX_SIZE" || fail "invalid plugin_log_max_size"

			validate_abs_path "$install_dir" || fail "invalid install_dir"
			boot_enabled="$(normalize_bool "$boot_enabled")" || fail "invalid boot_enabled"
			validate_host "$host" || fail "invalid host"
			validate_port "$port" || fail "invalid port"
			allow_wan_access="$(normalize_bool "$allow_wan_access")" || fail "invalid allow_wan_access"
			validate_log_size "$nora_log_max_size" || fail "invalid nora_log_max_size"
			validate_log_size "$plugin_log_max_size" || fail "invalid plugin_log_max_size"

			if [ "$install_dir" != "$CFG_INSTALL_DIR" ] || [ "$host" != "$CFG_HOST" ] || [ "$port" != "$CFG_PORT" ]; then
				restart_nora=1
			fi

			CFG_HOST="$host"
			CFG_PORT="$port"
			normalize_public_url
			validate_url_or_empty "$CFG_PUBLIC_URL" || fail "invalid public_url"

			ensure_uci_section
			delete_uci_option enabled
			set_uci_option install_dir "$install_dir"
			set_uci_option host "$host"
			set_uci_option port "$port"
			delete_uci_option public_url
			set_uci_option allow_wan_access "$allow_wan_access"
			set_uci_option nora_log_max_size "$nora_log_max_size"
			set_uci_option plugin_log_max_size "$plugin_log_max_size"
			if [ -x "$SERVICE_SCRIPT" ]; then
				if [ "$boot_enabled" -eq 1 ]; then
					"$SERVICE_SCRIPT" enable >/dev/null 2>&1 || fail "failed to enable init.d service"
				else
					"$SERVICE_SCRIPT" disable >/dev/null 2>&1 || fail "failed to disable init.d service"
				fi
			fi
			changed=1
			apply_firewall=1
			;;
		auth)
			local auth_enabled anonymous_read htpasswd_file token_storage
			json_get_setting_value auth_enabled auth_enabled "$CFG_AUTH_ENABLED" || fail "invalid auth_enabled"
			json_get_setting_value anonymous_read anonymous_read "$CFG_ANONYMOUS_READ" || fail "invalid anonymous_read"
			json_get_setting_value htpasswd_file htpasswd_file "$CFG_HTPASSWD_FILE" || fail "invalid htpasswd_file"
			json_get_setting_value token_storage token_storage "$CFG_TOKEN_STORAGE" || fail "invalid token_storage"

			auth_enabled="$(normalize_bool "$auth_enabled")" || fail "invalid auth_enabled"
			anonymous_read="$(normalize_bool "$anonymous_read")" || fail "invalid anonymous_read"
			validate_abs_path "$htpasswd_file" || fail "invalid htpasswd_file"
			validate_abs_path "$token_storage" || fail "invalid token_storage"

			if [ "$auth_enabled" != "$CFG_AUTH_ENABLED" ] || [ "$anonymous_read" != "$CFG_ANONYMOUS_READ" ] || [ "$htpasswd_file" != "$CFG_HTPASSWD_FILE" ] || [ "$token_storage" != "$CFG_TOKEN_STORAGE" ]; then
				restart_nora=1
			fi

			ensure_uci_section
			set_uci_option auth_enabled "$auth_enabled"
			set_uci_option anonymous_read "$anonymous_read"
			set_uci_option htpasswd_file "$htpasswd_file"
			set_uci_option token_storage "$token_storage"
			changed=1
			;;
		registry)
			local npm_enabled npm_proxy npm_proxy_timeout npm_metadata_ttl storage_path
			json_get_setting_value npm_enabled npm_enabled "$CFG_NPM_ENABLED" || fail "invalid npm_enabled"
			json_get_setting_value npm_proxy npm_proxy "$CFG_NPM_PROXY" || fail "invalid npm_proxy"
			json_get_setting_value npm_proxy_timeout npm_proxy_timeout "$CFG_NPM_PROXY_TIMEOUT" || fail "invalid npm_proxy_timeout"
			json_get_setting_value npm_metadata_ttl npm_metadata_ttl "$CFG_NPM_METADATA_TTL" || fail "invalid npm_metadata_ttl"
			json_get_setting_value storage_path storage_path "$CFG_STORAGE_PATH" || fail "invalid storage_path"

			npm_enabled="$(normalize_bool "$npm_enabled")" || fail "invalid npm_enabled"
			validate_url_or_empty "$npm_proxy" || fail "invalid npm_proxy"
			validate_timeout "$npm_proxy_timeout" || fail "invalid npm_proxy_timeout"
			validate_timeout "$npm_metadata_ttl" || fail "invalid npm_metadata_ttl"
			validate_abs_path "$storage_path" || fail "invalid storage_path"

			if [ "$npm_enabled" != "$CFG_NPM_ENABLED" ] || [ "$npm_proxy" != "$CFG_NPM_PROXY" ] || [ "$npm_proxy_timeout" != "$CFG_NPM_PROXY_TIMEOUT" ] || [ "$npm_metadata_ttl" != "$CFG_NPM_METADATA_TTL" ] || [ "$storage_path" != "$CFG_STORAGE_PATH" ]; then
				restart_nora=1
			fi

			ensure_uci_section
			set_uci_option npm_enabled "$npm_enabled"
			set_uci_option npm_proxy "$npm_proxy"
			set_uci_option npm_proxy_timeout "$npm_proxy_timeout"
			set_uci_option npm_metadata_ttl "$npm_metadata_ttl"
			set_uci_option storage_path "$storage_path"
			changed=1
			;;
		version)
			local architecture
			json_get_setting_value architecture architecture "$CFG_ARCHITECTURE" || fail "invalid architecture"
			validate_architecture "$architecture" || fail "invalid architecture"
			ensure_uci_section
			set_uci_option architecture "$architecture"
			changed=1
			;;
		*)
			fail "unknown settings section: $section"
			;;
	esac

	if [ "$changed" -eq 1 ]; then
		finish_save_settings "$section" "$apply_firewall" "$restart_nora"
	fi
	ok_message "save-settings" "$SAVE_SETTINGS_MESSAGE"
}

nora_binary_release_url() {
	local tag="$1" architecture="$2" asset
	asset="nora-linux-$architecture"

	if [ "$tag" = "latest" ]; then
		printf 'https://github.com/%s/releases/latest/download/%s' "$NORA_REPO" "$asset"
	else
		printf 'https://github.com/%s/releases/download/%s/%s' "$NORA_REPO" "$tag" "$asset"
	fi
}

download_nora_binary_asset() {
	local url="$1" destination="$2"

	rm -f "$destination"
	wget -q -O "$destination" "$url" || fail "download failed"
	[ -s "$destination" ] || fail "downloaded file is empty"
}

install_nora_binary_candidate() {
	local source="$1" target_tmp="$2" stage_error="$3" verify_error="$4"
	local binary previous

	binary="$CFG_INSTALL_DIR/bin/nora"
	previous="$CFG_INSTALL_DIR/bin/nora.previous"
	rm -f "$target_tmp"
	cp "$source" "$target_tmp" || fail "$stage_error"
	chmod 0755 "$target_tmp" || fail "failed to chmod binary"
	NORA_BINARY_DETECTED_VERSION="$(detect_nora_binary_version "$target_tmp" || true)"
	[ -n "$NORA_BINARY_DETECTED_VERSION" ] || fail "$verify_error"
	if [ -e "$binary" ]; then
		cp -fp "$binary" "$previous" || fail "failed to back up previous binary"
	fi
	mv -f "$target_tmp" "$binary" || {
		[ -e "$previous" ] && [ ! -e "$binary" ] && cp -fp "$previous" "$binary" >/dev/null 2>&1 || true
		fail "failed to replace binary"
	}
}

download_nora_binary() {
	local target_version="$1"
	local tag url tmp target_tmp binary version_output

	config_load_nora_binary_values
	mkdir -p "$CFG_INSTALL_DIR/bin" || fail "failed to create binary directory"
	require_command wget
	validate_version "$target_version" || fail "invalid install version"

	binary="$CFG_INSTALL_DIR/bin/nora"
	tag="$(normalize_nora_version "$target_version")"
	url="$(nora_binary_release_url "$tag" "$CFG_RESOLVED_ARCH")"
	plugin_log INFO "$2" "downloading Nora binary version=$tag arch=$CFG_RESOLVED_ARCH url=$url"

	tmp="/tmp/nora-download.$$"
	target_tmp="$CFG_INSTALL_DIR/bin/.nora.new.$$"
	download_nora_binary_asset "$url" "$tmp"
	install_nora_binary_candidate "$tmp" "$target_tmp" "failed to stage binary" "downloaded binary failed basic execution check"
	version_output="$NORA_BINARY_DETECTED_VERSION"
	rm -f "$tmp"
	plugin_log INFO "$2" "installed Nora binary version=$tag arch=$CFG_RESOLVED_ARCH detected_version=$version_output path=$binary"

	json_init
	json_add_boolean success 1
	json_add_string action "$2"
	json_add_string version "$tag"
	json_add_string architecture "$CFG_RESOLVED_ARCH"
	json_add_string url "$url"
	json_add_string binary "$binary"
	json_add_string detected_version "$version_output"
	json_dump
}

upload_nora_binary() {
	local upload_path="$1"
	local target_tmp binary version_output

	config_load_nora_binary_values
	validate_upload_path "$upload_path" || fail "invalid upload path"
	[ -s "$upload_path" ] || fail "uploaded binary is empty"
	mkdir -p "$CFG_INSTALL_DIR/bin" || fail "failed to create binary directory"
	plugin_log INFO upload-binary "staging uploaded Nora binary path=$upload_path"

	binary="$CFG_INSTALL_DIR/bin/nora"
	target_tmp="$CFG_INSTALL_DIR/bin/.nora.upload.$$"
	install_nora_binary_candidate "$upload_path" "$target_tmp" "failed to stage uploaded binary" "uploaded binary failed basic execution check"
	version_output="$NORA_BINARY_DETECTED_VERSION"
	rm -f "$upload_path"
	plugin_log INFO upload-binary "installed uploaded Nora binary detected_version=$version_output path=$binary"

	json_init
	json_add_boolean success 1
	json_add_string action "upload-binary"
	json_add_string binary "$binary"
	json_add_string detected_version "$version_output"
	json_dump
}

service_action() {
	local action="$1"
	local binary

	[ -x "$SERVICE_SCRIPT" ] || fail "service script missing"
	plugin_log INFO "$action" "service action requested"

	case "$action" in
		start|restart)
			config_load_values
			binary="$CFG_INSTALL_DIR/bin/nora"
			[ -x "$binary" ] || fail "Nora binary is not installed"
			if [ "$CFG_AUTH_ENABLED" -eq 1 ]; then
				[ -s "$CFG_HTPASSWD_FILE" ] || fail "upload an htpasswd entry before starting Nora"
			fi
			render_nora_config >/dev/null 2>&1 || fail "failed to render Nora config before start"
			;;
	esac

	"$SERVICE_SCRIPT" "$action" >/dev/null 2>&1 || fail "service action failed: $action"
	plugin_log INFO "$action" "service $action command completed"

	case "$action" in
		start|restart)
			sleep 1
			detect_running "$binary" || fail "Nora exited during startup; check logread -e nora"
			plugin_log INFO "$action" "Nora running after service $action"
			if [ "$CFG_ALLOW_WAN_ACCESS" -eq 1 ]; then
				plugin_log INFO "$action" "applying firewall after service $action"
				firewall_apply >/dev/null 2>&1 || fail "service started but failed to apply firewall rule"
			fi
			;;
		stop)
			plugin_log INFO stop "removing firewall rule after service stop"
			firewall_delete >/dev/null 2>&1 || fail "service stopped but failed to remove firewall rule"
			;;
	esac

	ok_message "$action" "$action ok"
}

service_boot_enabled() {
	[ -x "$SERVICE_SCRIPT" ] && "$SERVICE_SCRIPT" enabled >/dev/null 2>&1
}

set_htpasswd() {
	local line="$1"
	local tmp message
	config_load_htpasswd_values
	validate_htpasswd_line "$line" || fail "invalid bcrypt htpasswd line"
	mkdir -p "$(dirname "$CFG_HTPASSWD_FILE")" || fail "failed to create htpasswd directory"
	tmp="$CFG_HTPASSWD_FILE.tmp.$$"
	umask 077
	printf '%s\n' "$line" > "$tmp" || fail "failed to write temporary htpasswd file"
	chmod 0600 "$tmp" || fail "failed to chmod htpasswd file"
	mv -f "$tmp" "$CFG_HTPASSWD_FILE" || fail "failed to replace htpasswd file"
	message="htpasswd updated"
	if [ -x "$CFG_INSTALL_DIR/bin/nora" ] && detect_running "$CFG_INSTALL_DIR/bin/nora"; then
		[ -x "$SERVICE_SCRIPT" ] || fail "htpasswd updated but service script missing"
		"$SERVICE_SCRIPT" restart >/dev/null 2>&1 || fail "htpasswd updated but restart failed"
		message="$message and Nora restarted"
	else
		message="$message without restart"
	fi
	ok_message "set-htpasswd" "$message"
}

firewall_reload() {
	if [ -x /etc/init.d/firewall ]; then
		/etc/init.d/firewall reload >/dev/null 2>&1 || /etc/init.d/firewall restart >/dev/null 2>&1 || fail "failed to reload firewall"
	fi
}

firewall_delete() {
	command -v uci >/dev/null 2>&1 || fail "uci command missing"

	uci -q delete firewall.nora >/dev/null 2>&1 || true
	uci commit firewall || fail "failed to commit firewall"
	firewall_reload
}

firewall_apply() {
	config_load_firewall_values
	command -v uci >/dev/null 2>&1 || fail "uci command missing"

	if [ "$CFG_ALLOW_WAN_ACCESS" -eq 1 ]; then
		uci -q delete firewall.nora >/dev/null 2>&1
		uci set firewall.nora=rule || fail "failed to create firewall section"
		uci set firewall.nora.name='Allow-Nora' || fail "failed to set firewall name"
		uci set firewall.nora.src='wan' || fail "failed to set firewall src"
		uci set firewall.nora.proto='tcp' || fail "failed to set firewall proto"
		uci set firewall.nora.dest_port="$CFG_PORT" || fail "failed to set firewall port"
		uci set firewall.nora.target='ACCEPT' || fail "failed to set firewall target"
		uci commit firewall || fail "failed to commit firewall"
	else
		firewall_delete
		ok_message "firewall-apply" "firewall updated"
		return 0
	fi

	firewall_reload

	ok_message "firewall-apply" "firewall updated"
}

detect_running() {
	local binary="$1"

	if [ -x "$SERVICE_SCRIPT" ] && "$SERVICE_SCRIPT" running >/dev/null 2>&1; then
		return 0
	fi
	if command -v pidof >/dev/null 2>&1 && pidof nora >/dev/null 2>&1; then
		return 0
	fi
	if command -v pgrep >/dev/null 2>&1 && pgrep -f -x "$binary" >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

collect_status() {
	local binary config_path installed running htpasswd_present detected_version
	config_load_raw_values
	normalize_public_url
	CFG_RESOLVED_ARCH="$(resolve_architecture "$CFG_ARCHITECTURE" 2>/dev/null || true)"
	binary="$CFG_INSTALL_DIR/bin/nora"
	config_path="$CFG_INSTALL_DIR/config/config.toml"
	installed=0
	running=0
	htpasswd_present=0
	[ -x "$binary" ] && installed=1
	[ -s "$CFG_HTPASSWD_FILE" ] && htpasswd_present=1
	if detect_running "$binary"; then
		running=1
	fi
	if [ "$installed" -eq 1 ]; then
		detected_version="$(detect_nora_binary_version "$binary" || true)"
	fi
	json_init
	json_add_boolean success 1
	json_add_boolean installed "$installed"
	json_add_boolean running "$running"
	json_add_boolean boot_enabled "$(service_boot_enabled && printf 1 || printf 0)"
	json_add_string install_dir "$CFG_INSTALL_DIR"
	json_add_string version "$CFG_VERSION"
	json_add_string architecture "$CFG_ARCHITECTURE"
	json_add_string resolved_architecture "$CFG_RESOLVED_ARCH"
	json_add_string binary "$binary"
	json_add_string config_path "$config_path"
	json_add_boolean config_present "$( [ -s "$config_path" ] && printf 1 || printf 0 )"
	json_add_boolean auth_enabled "$CFG_AUTH_ENABLED"
	json_add_boolean anonymous_read "$CFG_ANONYMOUS_READ"
	json_add_string htpasswd_file "$CFG_HTPASSWD_FILE"
	json_add_boolean htpasswd_present "$htpasswd_present"
	json_add_boolean npm_enabled "$CFG_NPM_ENABLED"
	json_add_string npm_proxy "$CFG_NPM_PROXY"
	json_add_int npm_proxy_timeout "$CFG_NPM_PROXY_TIMEOUT"
	json_add_int npm_metadata_ttl "$CFG_NPM_METADATA_TTL"
	json_add_boolean allow_wan_access "$CFG_ALLOW_WAN_ACCESS"
	json_add_string public_url "$CFG_PUBLIC_URL"
	json_add_string host "$CFG_HOST"
	json_add_int port "$CFG_PORT"
	json_add_string storage_path "$CFG_STORAGE_PATH"
	json_add_string token_storage "$CFG_TOKEN_STORAGE"
	json_add_string installed_version "$detected_version"
	json_dump
}

read_uci_config() {
	config_load_raw_values
	json_init
	json_add_boolean success 1

	json_add_object global
	json_add_string install_dir "$CFG_INSTALL_DIR"
	json_add_boolean boot_enabled "$(service_boot_enabled && printf 1 || printf 0)"
	json_add_string host "$CFG_HOST"
	json_add_int port "$CFG_PORT"
	json_add_boolean allow_wan_access "$CFG_ALLOW_WAN_ACCESS"
	json_add_int nora_log_max_size "$CFG_NORA_LOG_MAX_SIZE"
	json_add_int plugin_log_max_size "$CFG_PLUGIN_LOG_MAX_SIZE"
	json_close_object

	json_add_object auth
	json_add_boolean auth_enabled "$CFG_AUTH_ENABLED"
	json_add_boolean anonymous_read "$CFG_ANONYMOUS_READ"
	json_add_string htpasswd_file "$CFG_HTPASSWD_FILE"
	json_add_string token_storage "$CFG_TOKEN_STORAGE"
	json_close_object

	json_add_object registry
	json_add_boolean npm_enabled "$CFG_NPM_ENABLED"
	json_add_string npm_proxy "$CFG_NPM_PROXY"
	json_add_int npm_proxy_timeout "$CFG_NPM_PROXY_TIMEOUT"
	json_add_int npm_metadata_ttl "$CFG_NPM_METADATA_TTL"
	json_add_string storage_path "$CFG_STORAGE_PATH"
	json_close_object

	json_add_object version
	json_add_string version "$CFG_VERSION"
	json_add_string architecture "$CFG_ARCHITECTURE"
	json_close_object

	json_dump
}

# -----------------------------------------------------------------------------
# Plugin operations
# -----------------------------------------------------------------------------

plugin_current_version() {
	command -v opkg >/dev/null 2>&1 || return 1
	opkg status "$PLUGIN_PACKAGE" 2>/dev/null | sed -n 's/^Version:[[:space:]]*//p' | sed -n '1p'
}

detect_plugin_latest_release() {
	github_latest_release "$PLUGIN_REPO"
}

plugin_release_ipk_url_from_json() {
	sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*luci-app-nora_[^"]*_all\.ipk\)".*/\1/p' | sed -n '1p'
}

plugin_release_sha256_url_from_json() {
	sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*luci-app-nora_[^"]*_all\.ipk\.sha256\)".*/\1/p' | sed -n '1p'
}

plugin_release_i18n_ipk_url_from_json() {
	sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*luci-i18n-nora-zh-cn_[^"]*_all\.ipk\)".*/\1/p' | sed -n '1p'
}

plugin_release_i18n_sha256_url_from_json() {
	sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*luci-i18n-nora-zh-cn_[^"]*_all\.ipk\.sha256\)".*/\1/p' | sed -n '1p'
}

plugin_asset_name_from_url() {
	local url="$1"
	printf '%s' "${url##*/}"
}

plugin_version_from_ipk_name() {
	local name="$1" version
	version="${name#luci-app-nora_}"
	version="${version%_all.ipk}"
	[ "$version" != "$name" ] || return 1
	printf '%s' "$version"
}

plugin_i18n_version_from_ipk_name() {
	local name="$1" version
	version="${name#luci-i18n-nora-zh-cn_}"
	version="${version%_all.ipk}"
	[ "$version" != "$name" ] || return 1
	printf '%s' "$version"
}

validate_plugin_asset_url() {
	local url="$1"
	case "$url" in
		https://github.com/$PLUGIN_REPO/releases/download/*/luci-app-nora_*_all.ipk|https://github.com/$PLUGIN_REPO/releases/download/*/luci-app-nora_*_all.ipk.sha256|https://github.com/$PLUGIN_REPO/releases/download/*/luci-i18n-nora-zh-cn_*_all.ipk|https://github.com/$PLUGIN_REPO/releases/download/*/luci-i18n-nora-zh-cn_*_all.ipk.sha256) return 0 ;;
		*) return 1 ;;
	esac
}

collect_plugin_latest_version() {
	local release_json latest_version package_version i18n_package_version ipk_url sha256_url i18n_ipk_url i18n_sha256_url ipk_name i18n_ipk_name current_version upgrade_available
	release_json="$(detect_plugin_latest_release || true)"
	latest_version="$(printf '%s\n' "$release_json" | github_release_tag_from_json)"
	ipk_url="$(printf '%s\n' "$release_json" | plugin_release_ipk_url_from_json)"
	sha256_url="$(printf '%s\n' "$release_json" | plugin_release_sha256_url_from_json)"
	i18n_ipk_url="$(printf '%s\n' "$release_json" | plugin_release_i18n_ipk_url_from_json)"
	i18n_sha256_url="$(printf '%s\n' "$release_json" | plugin_release_i18n_sha256_url_from_json)"
	ipk_name="$(plugin_asset_name_from_url "$ipk_url")"
	i18n_ipk_name="$(plugin_asset_name_from_url "$i18n_ipk_url")"
	package_version="$(plugin_version_from_ipk_name "$ipk_name" 2>/dev/null || true)"
	i18n_package_version="$(plugin_i18n_version_from_ipk_name "$i18n_ipk_name" 2>/dev/null || true)"
	current_version="$(plugin_current_version || true)"
	upgrade_available=0
	[ -n "$package_version" ] && [ -n "$current_version" ] && [ "$package_version" != "$current_version" ] && upgrade_available=1

	json_init
	json_add_boolean success 1
	json_add_string action plugin-latest-version
	json_add_string package "$PLUGIN_PACKAGE"
	json_add_string i18n_package "$PLUGIN_I18N_PACKAGE"
	json_add_string repository "$PLUGIN_REPO"
	json_add_string current_version "$current_version"
	json_add_string latest_version "$latest_version"
	json_add_string package_version "$package_version"
	json_add_string i18n_package_version "$i18n_package_version"
	json_add_string ipk_name "$ipk_name"
	json_add_string i18n_ipk_name "$i18n_ipk_name"
	json_add_string ipk_url "$ipk_url"
	json_add_string sha256_url "$sha256_url"
	json_add_string i18n_ipk_url "$i18n_ipk_url"
	json_add_string i18n_sha256_url "$i18n_sha256_url"
	json_add_boolean upgrade_available "$upgrade_available"
	json_dump
}

collect_plugin_status() {
	local current_version opkg_available wget_available sha256sum_available
	current_version="$(plugin_current_version || true)"
	opkg_available=0; wget_available=0; sha256sum_available=0
	command -v opkg >/dev/null 2>&1 && opkg_available=1
	command -v wget >/dev/null 2>&1 && wget_available=1
	command -v sha256sum >/dev/null 2>&1 && sha256sum_available=1

	json_init
	json_add_boolean success 1
	json_add_string action plugin-status
	json_add_string package "$PLUGIN_PACKAGE"
	json_add_string i18n_package "$PLUGIN_I18N_PACKAGE"
	json_add_string repository "$PLUGIN_REPO"
	json_add_string current_version "$current_version"
	json_add_boolean installed "$( [ -n "$current_version" ] && printf 1 || printf 0 )"
	json_add_boolean opkg_available "$opkg_available"
	json_add_boolean wget_available "$wget_available"
	json_add_boolean sha256sum_available "$sha256sum_available"
	json_dump
}

plugin_upgrade() {
	local release_json latest_version package_version i18n_package_version ipk_url sha256_url i18n_ipk_url i18n_sha256_url ipk_name sha256_name i18n_ipk_name i18n_sha256_name tmp_ipk tmp_sha tmp_i18n_ipk tmp_i18n_sha expected actual expected_i18n actual_i18n install_output

	require_command wget
	require_command opkg
	require_command sha256sum
	plugin_log INFO plugin-upgrade "checking latest plugin release"

	release_json="$(detect_plugin_latest_release || true)"
	latest_version="$(printf '%s\n' "$release_json" | github_release_tag_from_json)"
	ipk_url="$(printf '%s\n' "$release_json" | plugin_release_ipk_url_from_json)"
	sha256_url="$(printf '%s\n' "$release_json" | plugin_release_sha256_url_from_json)"
	i18n_ipk_url="$(printf '%s\n' "$release_json" | plugin_release_i18n_ipk_url_from_json)"
	i18n_sha256_url="$(printf '%s\n' "$release_json" | plugin_release_i18n_sha256_url_from_json)"
	[ -n "$latest_version" ] || fail "plugin latest release not found"
	[ -n "$ipk_url" ] || fail "plugin ipk asset not found in latest release"
	[ -n "$sha256_url" ] || fail "plugin sha256 asset not found in latest release"
	validate_plugin_asset_url "$ipk_url" || fail "invalid plugin ipk download url"
	validate_plugin_asset_url "$sha256_url" || fail "invalid plugin sha256 download url"
	if [ -n "$i18n_ipk_url" ] && [ -n "$i18n_sha256_url" ]; then
		validate_plugin_asset_url "$i18n_ipk_url" || fail "invalid plugin i18n ipk download url"
		validate_plugin_asset_url "$i18n_sha256_url" || fail "invalid plugin i18n sha256 download url"
	elif [ -n "$i18n_ipk_url" ] || [ -n "$i18n_sha256_url" ]; then
		plugin_log WARN plugin-upgrade "plugin i18n assets incomplete; skipping i18n package"
		i18n_ipk_url=""
		i18n_sha256_url=""
	fi

	ipk_name="$(plugin_asset_name_from_url "$ipk_url")"
	package_version="$(plugin_version_from_ipk_name "$ipk_name" 2>/dev/null || true)"
	sha256_name="$(plugin_asset_name_from_url "$sha256_url")"
	tmp_ipk="/tmp/$ipk_name"
	tmp_sha="/tmp/$sha256_name"
	if [ -n "$i18n_ipk_url" ] && [ -n "$i18n_sha256_url" ]; then
		i18n_ipk_name="$(plugin_asset_name_from_url "$i18n_ipk_url")"
		i18n_package_version="$(plugin_i18n_version_from_ipk_name "$i18n_ipk_name" 2>/dev/null || true)"
		i18n_sha256_name="$(plugin_asset_name_from_url "$i18n_sha256_url")"
		tmp_i18n_ipk="/tmp/$i18n_ipk_name"
		tmp_i18n_sha="/tmp/$i18n_sha256_name"
	else
		i18n_ipk_name=""
		i18n_package_version=""
		i18n_sha256_name=""
		tmp_i18n_ipk=""
		tmp_i18n_sha=""
	fi
	rm -f "$tmp_ipk" "$tmp_sha" "$tmp_i18n_ipk" "$tmp_i18n_sha"
	plugin_log INFO plugin-upgrade "downloading plugin version=$latest_version ipk=$ipk_name"
	wget -q -O "$tmp_ipk" "$ipk_url" || fail "plugin ipk download failed"
	[ -s "$tmp_ipk" ] || fail "downloaded plugin ipk is empty"
	wget -q -O "$tmp_sha" "$sha256_url" || fail "plugin sha256 download failed"
	[ -s "$tmp_sha" ] || fail "downloaded plugin sha256 is empty"
	if [ -n "$tmp_i18n_ipk" ]; then
		plugin_log INFO plugin-upgrade "downloading plugin i18n version=$latest_version ipk=$i18n_ipk_name"
		wget -q -O "$tmp_i18n_ipk" "$i18n_ipk_url" || fail "plugin i18n ipk download failed"
		[ -s "$tmp_i18n_ipk" ] || fail "downloaded plugin i18n ipk is empty"
		wget -q -O "$tmp_i18n_sha" "$i18n_sha256_url" || fail "plugin i18n sha256 download failed"
		[ -s "$tmp_i18n_sha" ] || fail "downloaded plugin i18n sha256 is empty"
	fi
	expected="$(sed -n 's/^\([A-Fa-f0-9]\{64\}\).*/\1/p' "$tmp_sha" | sed -n '1p')"
	[ -n "$expected" ] || fail "invalid plugin sha256 file"
	actual="$(sha256sum "$tmp_ipk" 2>/dev/null | awk '{print $1}')"
	[ -n "$actual" ] || fail "failed to calculate plugin ipk sha256"
	[ "$expected" = "$actual" ] || fail "plugin ipk sha256 mismatch"
	if [ -n "$tmp_i18n_ipk" ]; then
		expected_i18n="$(sed -n 's/^\([A-Fa-f0-9]\{64\}\).*/\1/p' "$tmp_i18n_sha" | sed -n '1p')"
		[ -n "$expected_i18n" ] || fail "invalid plugin i18n sha256 file"
		actual_i18n="$(sha256sum "$tmp_i18n_ipk" 2>/dev/null | awk '{print $1}')"
		[ -n "$actual_i18n" ] || fail "failed to calculate plugin i18n ipk sha256"
		[ "$expected_i18n" = "$actual_i18n" ] || fail "plugin i18n ipk sha256 mismatch"
	else
		actual_i18n=""
	fi

	rm -f "$NEEDS_RPCD_RELOAD_MARKER" >/dev/null 2>&1 || true
	: > "$DEFER_RPCD_RELOAD_MARKER"
	if [ -n "$tmp_i18n_ipk" ]; then
		install_output="$(opkg install "$tmp_ipk" "$tmp_i18n_ipk" 2>&1)" || {
			rm -f "$DEFER_RPCD_RELOAD_MARKER" "$NEEDS_RPCD_RELOAD_MARKER" >/dev/null 2>&1 || true
			fail "plugin install failed: $install_output"
		}
	else
		install_output="$(opkg install "$tmp_ipk" 2>&1)" || {
			rm -f "$DEFER_RPCD_RELOAD_MARKER" "$NEEDS_RPCD_RELOAD_MARKER" >/dev/null 2>&1 || true
			fail "plugin install failed: $install_output"
		}
	fi
	rm -f "$DEFER_RPCD_RELOAD_MARKER" >/dev/null 2>&1 || true
	rm -f "$tmp_ipk" "$tmp_sha" "$tmp_i18n_ipk" "$tmp_i18n_sha" >/dev/null 2>&1 || true
	plugin_log INFO plugin-upgrade "plugin upgraded version=$latest_version package_version=$package_version i18n_package_version=$i18n_package_version sha256=$actual i18n_sha256=$actual_i18n"
	if [ -f "$NEEDS_RPCD_RELOAD_MARKER" ]; then
		(
			sleep 2
			rm -f "$NEEDS_RPCD_RELOAD_MARKER" >/dev/null 2>&1 || true
			/etc/init.d/rpcd reload >/dev/null 2>&1 || true
		) >/dev/null 2>&1 &
		plugin_log INFO plugin-upgrade "scheduled deferred rpcd reload"
	fi

	json_init
	json_add_boolean success 1
	json_add_string action plugin-upgrade
	json_add_string message "plugin upgraded; refresh this page"
	json_add_string package "$PLUGIN_PACKAGE"
	json_add_string i18n_package "$PLUGIN_I18N_PACKAGE"
	json_add_string version "$latest_version"
	json_add_string package_version "$package_version"
	json_add_string i18n_package_version "$i18n_package_version"
	json_add_string ipk_name "$ipk_name"
	json_add_string i18n_ipk_name "$i18n_ipk_name"
	json_add_string sha256 "$actual"
	json_add_string i18n_sha256 "$actual_i18n"
	json_dump
}

# -----------------------------------------------------------------------------
# Command dispatch
# -----------------------------------------------------------------------------

usage() {
	fail "usage: nora-control {status|latest-version|plugin-status|plugin-latest-version|plugin-upgrade|read-uci-config|logs|install|upgrade|upload-binary|render-nora-config|read-nora-config|save-settings|start|stop|restart|set-htpasswd|firewall-apply}"
}

main() {
	case "$1" in
		status)
			collect_status
			;;
		latest-version)
			collect_nora_latest_version
			;;
		plugin-status)
			collect_plugin_status
			;;
		plugin-latest-version)
			collect_plugin_latest_version
			;;
		plugin-upgrade)
			plugin_upgrade
			;;
		read-uci-config)
			read_uci_config
			;;
		logs)
			read_logs "$2" "$3" "$4"
			;;
		install)
			download_nora_binary "${2:-latest}" "install"
			;;
		upgrade)
			download_nora_binary "latest" "upgrade"
			;;
		upload-binary)
			[ $# -eq 2 ] || fail "upload-binary requires uploaded file path"
			upload_nora_binary "$2"
			;;
		render-nora-config|render-config)
			render_nora_config
			;;
		read-nora-config)
			read_nora_config
			;;
		save-settings)
			[ $# -eq 2 ] || fail "save-settings requires section name (global|auth|registry|version)"
			save_settings "$2"
			;;
		start|stop|restart)
			service_action "$1"
			;;
		set-htpasswd)
			[ $# -eq 2 ] || fail "set-htpasswd requires one bcrypt htpasswd line"
			set_htpasswd "$2"
			;;
		firewall-apply)
			firewall_apply
			;;
		*)
			usage
			;;
	esac
}

main "$@"
